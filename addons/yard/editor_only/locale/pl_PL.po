msgstr ""
"Nieprawidłowa klasa/skrypt. Oczekiwana podklasa Resource (wbudowana, class_name lub "
"[u]cytowana[/u] ścieżka skryptu)."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid "No class filter, all Resource files will be accepted to the registry."
msgstr "Brak filtra klas, wszystkie pliki Resource zostaną przyjęte do rejestru."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
